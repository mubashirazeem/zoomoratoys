<div
  data-cart-drawer-target="panel"
  class="hidden fixed inset-0 z-50"
  tabindex="-1"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping cart"
>
  <div class="absolute inset-0 bg-ink-950/50" data-action="click->cart-drawer#close"></div>

  <div class="absolute inset-y-0 right-0 w-full max-w-sm bg-white shadow-elevated flex flex-col">
    <div class="flex items-center justify-between px-5 py-4 border-b border-grey-200">
      <div>
        <h2 class="font-display font-bold text-h3 text-ink-950">Shopping Cart</h2>
        <p class="text-body-sm text-grey-500"><%= products.size %> <%= "item".pluralize(products.size) %></p>
      </div>
      <button
        type="button"
        data-action="cart-drawer#close"
        aria-label="Close cart"
        class="flex items-center justify-center w-10 h-10 rounded-full text-ink-950 hover:bg-grey-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-600"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" class="w-5 h-5" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>

    <% if products.none? %>
      <div class="flex-1 flex flex-col items-center justify-center gap-4 px-5 text-center">
        <span class="flex items-center justify-center w-14 h-14 rounded-full bg-grey-100 text-grey-400">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6" aria-hidden="true"><path d="M4 5h2l2 12h9l2-8H7"/><circle cx="9" cy="20" r="1"/><circle cx="17" cy="20" r="1"/></svg>
        </span>
        <p class="text-body text-grey-600">Your cart is empty.</p>
        <%= render(Ui::ButtonComponent.new(variant: :primary, size: :base, href: products_path)) { "Start Shopping" } %>
      </div>
    <% else %>
      <div class="flex-1 overflow-y-auto px-5 py-4" data-controller="cart">
        <div class="rounded-[12px] bg-grey-50 border border-grey-200 p-3">
          <p class="flex items-center gap-2 text-body-sm font-medium text-ink-950">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-red-600 shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            You qualify for free UAE delivery!
          </p>
          <div class="mt-2 h-1.5 rounded-full bg-red-600" aria-hidden="true"></div>
        </div>

        <ul class="mt-4 flex flex-col divide-y divide-grey-200">
          <% products.each do |product| %>
            <li data-cart-target="line" data-price-cents="<%= product.price_cents %>" class="flex gap-3 py-4 first:pt-0">
              <%= link_to product_path(product), class: "shrink-0" do %>
                <%= image_tag "category-#{product.placeholder_key}.jpg", alt: "", class: "w-16 h-16 rounded-[10px] object-cover bg-grey-50" %>
              <% end %>
              <div class="flex-1 min-w-0">
                <%= link_to product.name, product_path(product), class: "block text-body-sm font-medium text-ink-950 hover:text-red-600 line-clamp-2" %>
                <p class="mt-0.5 text-[12px] text-grey-500"><%= product.category.name %></p>
                <div class="mt-2 flex items-center justify-between">
                  <div class="inline-flex items-center rounded-full border border-grey-300 overflow-hidden" data-controller="quantity">
                    <button type="button" data-action="quantity#decrease cart#recalculate" aria-label="Decrease quantity" class="w-7 h-7 flex items-center justify-center text-ink-950 hover:bg-grey-50">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="w-3 h-3" aria-hidden="true"><path d="M5 12h14"/></svg>
                    </button>
                    <input type="text" inputmode="numeric" value="1" data-quantity-target="input" data-action="input->cart#recalculate" aria-label="Quantity for <%= product.name %>" class="w-8 h-7 text-center text-[12px] font-semibold text-ink-950 focus:outline-none" />
                    <button type="button" data-action="quantity#increase cart#recalculate" aria-label="Increase quantity" class="w-7 h-7 flex items-center justify-center text-ink-950 hover:bg-grey-50">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="w-3 h-3" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                    </button>
                  </div>
                  <span class="text-body-sm font-semibold text-ink-950" data-cart-target="lineTotal"><%= format_aed(product.price_cents) %></span>
                </div>
              </div>
              <button type="button" data-action="cart#removeLine" aria-label="Remove <%= product.name %> from cart" class="shrink-0 self-start w-7 h-7 flex items-center justify-center rounded-full text-grey-400 hover:bg-red-50 hover:text-red-600 transition-colors">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" class="w-3.5 h-3.5" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
              </button>
            </li>
          <% end %>
        </ul>

        <% if suggested_products.any? %>
          <div class="mt-5 pt-4 border-t border-grey-200">
            <p class="text-[11px] uppercase font-semibold tracking-[0.08em] text-grey-500 mb-3">You May Also Like</p>
            <div class="flex gap-3 overflow-x-auto pb-1" style="scrollbar-width: none;">
              <% suggested_products.each do |product| %>
                <%= link_to product_path(product), class: "shrink-0 w-28 group" do %>
                  <%= image_tag "category-#{product.placeholder_key}.jpg", alt: "", class: "w-28 h-28 rounded-[10px] object-cover bg-grey-50 transition-transform duration-300 group-hover:scale-105" %>
                  <p class="mt-1.5 text-[12px] text-ink-950 line-clamp-2 group-hover:text-red-600"><%= product.name %></p>
                  <p class="text-[12px] font-semibold text-ink-950"><%= format_aed(product.price_cents) %></p>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>

        <div class="mt-5 pt-4 border-t border-grey-200 flex flex-col gap-2 text-body-sm">
          <div class="flex justify-between">
            <span class="text-grey-600">Subtotal</span>
            <span class="font-semibold text-ink-950" data-cart-target="subtotal"><%= format_aed(subtotal_cents) %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-grey-600">Total</span>
            <span class="font-bold text-ink-950 text-[16px]" data-cart-target="total"><%= format_aed(subtotal_cents) %></span>
          </div>
          <p class="text-[12px] text-grey-500">Tax included. Shipping is free across the UAE.</p>
        </div>
      </div>

      <div class="border-t border-grey-200 p-5 flex flex-col gap-2.5">
        <%= render(Ui::ButtonComponent.new(variant: :secondary, size: :lg, full_width: true, href: "#")) { "Checkout" } %>
        <%= render(Ui::ButtonComponent.new(variant: :ghost, size: :lg, full_width: true, href: cart_path)) { "View Cart" } %>
      </div>
    <% end %>
  </div>
</div>
