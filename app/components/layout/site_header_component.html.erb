<div data-controller="nav-drawer header" data-header-threshold-value="260">

  <%# ---- Announcement bar (dismissable) ---- %>
  <div data-controller="dismissable" class="bg-[#ff8b21] text-ink-950">
    <div class="max-w-7xl mx-auto px-[40px] py-1.5 relative">
      <p class="text-[12px] font-medium text-center leading-5">
        Free UAE Delivery &amp; Installation &nbsp;•&nbsp; Buy Now, Pay Later Available &nbsp;•&nbsp; Family Adventure Store
      </p>
      <button type="button" data-action="dismissable#close" aria-label="Dismiss announcement"
        class="absolute top-1/2 right-[15px] -translate-y-1/2 flex items-center justify-center w-5 h-5 hover:opacity-70 focus-visible:outline focus-visible:outline-2 focus-visible:outline-ink-950">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="w-3.5 h-3.5" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" /></svg>
      </button>
    </div>
  </div>

  <%# ---- Desktop top group: utility bar + main bar ---- %>
  <div class="hidden lg:block">
    <div class="bg-grey-50 border-b border-grey-200">
      <div class="max-w-7xl mx-auto px-[15px] py-2 flex items-center gap-8 text-[12px] text-ink-950">
        <span class="flex items-center gap-2">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-grey-600" aria-hidden="true"><path d="M4 13v-1a8 8 0 0 1 16 0v1"/><path d="M4 13a2 2 0 0 1 2-2 2 2 0 0 1 2 2v2a2 2 0 0 1-2 2 2 2 0 0 1-2-2Z"/><path d="M20 13a2 2 0 0 0-2-2 2 2 0 0 0-2 2v2a2 2 0 0 0 2 2 2 2 0 0 0 2-2Z"/><path d="M18 17v1a2 2 0 0 1-2 2h-2"/></svg>
          <span class="font-medium">Toll-free:</span>
          <%= link_to Layout::SiteFooterComponent::SUPPORT_PHONE, "tel:#{Layout::SiteFooterComponent::SUPPORT_PHONE.gsub(/\s+/, '')}", class: "hover:text-red-600" %>
        </span>
        <span class="flex items-center gap-2">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-grey-600" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
          <%= link_to Layout::SiteFooterComponent::SUPPORT_EMAIL, "mailto:#{Layout::SiteFooterComponent::SUPPORT_EMAIL}", class: "hover:text-red-600" %>
        </span>
      </div>
    </div>

    <div class="bg-white">
      <div class="max-w-7xl mx-auto px-[15px] py-5 flex items-center gap-8">
        <%= link_to root_path, class: "shrink-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600" do %>
          <%= image_tag "logo.jpeg", alt: "Zoomora Toys — Adventure Starts Here", class: "h-12 w-auto" %>
        <% end %>

        <form action="<%= products_path %>" method="get" role="search" class="flex flex-1 max-w-2xl" data-turbo="false">
          <label for="store-search" class="sr-only">Search the store</label>
          <input type="search" id="store-search" name="q" placeholder="Search the store"
            class="flex-1 h-[52px] px-4 text-[13px] text-ink-950 border border-grey-300 border-r-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-600" />
          <button type="submit" aria-label="Search" class="w-[60px] h-[52px] flex items-center justify-center bg-red-600 text-white hover:bg-red-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          </button>
        </form>

        <div class="flex items-center gap-6 shrink-0 ml-auto text-[12px] text-ink-950">
          <a href="#" class="flex items-center gap-2 hover:text-red-600">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-3.3 3.6-6 8-6s8 2.7 8 6"/></svg>
            <span class="leading-tight"><span class="block text-grey-500">Hello</span><span class="block font-semibold">Sign In</span></span>
          </a>
          <a href="#" class="flex items-center gap-2 hover:text-red-600">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6" aria-hidden="true"><path d="M12 20s-7-4.3-7-9a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 4.7-7 9-7 9Z"/></svg>
            <span class="font-semibold">Wish Lists</span>
          </a>
          <a href="#" class="flex items-center gap-2 hover:text-red-600">
            <span class="relative">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6" aria-hidden="true"><path d="M4 5h2l2 12h9l2-8H7"/><circle cx="9" cy="20" r="1"/><circle cx="17" cy="20" r="1"/></svg>
              <span class="absolute -top-2 -right-2 min-w-[16px] h-4 px-1 flex items-center justify-center bg-red-600 text-white text-[10px] font-bold rounded-full">0</span>
            </span>
            <span class="font-semibold">Cart</span>
          </a>
          <span class="flex items-center gap-1.5 border border-grey-300 px-2.5 py-1.5 text-[12px] font-semibold cursor-default select-none">
            🇦🇪 AED
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-grey-600" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </span>
        </div>
      </div>
    </div>
  </div>

  <%# ---- Mobile top group: compact bar + search ---- %>
  <div class="lg:hidden bg-white border-b border-grey-200">
    <div class="max-w-7xl mx-auto px-[15px] h-14 flex items-center justify-between">
      <button type="button" data-action="nav-drawer#open" aria-label="Open menu"
        class="flex items-center justify-center w-10 h-10 -ml-2 text-ink-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-600">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" class="w-6 h-6" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
      </button>
      <%= link_to root_path, class: "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600" do %>
        <%= image_tag "logo.jpeg", alt: "Zoomora Toys", class: "h-9 w-auto" %>
      <% end %>
      <a href="#" aria-label="Cart" class="relative flex items-center justify-center w-10 h-10 -mr-2 text-ink-950">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6" aria-hidden="true"><path d="M4 5h2l2 12h9l2-8H7"/><circle cx="9" cy="20" r="1"/><circle cx="17" cy="20" r="1"/></svg>
        <span class="absolute top-1 right-0 min-w-[16px] h-4 px-1 flex items-center justify-center bg-red-600 text-white text-[10px] font-bold rounded-full">0</span>
      </a>
    </div>
    <div class="px-[15px] pb-3">
      <form action="<%= products_path %>" method="get" role="search" class="flex" data-turbo="false">
        <label for="store-search-mobile" class="sr-only">Search the store</label>
        <input type="search" id="store-search-mobile" name="q" placeholder="Search the store"
          class="flex-1 h-11 px-4 text-[13px] text-ink-950 border border-grey-300 border-r-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-600" />
        <button type="submit" aria-label="Search" class="w-12 h-11 flex items-center justify-center bg-red-600 text-white">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        </button>
      </form>
    </div>
  </div>

  <%# ---- Primary nav (desktop, sticky, condenses on scroll) ---- %>
  <%# Dark glossy 3D bar: raised red button-pills lift on hover, the current %>
  <%# page shows a pressed-in active pill. See .nav3d rules in the layout head. %>
  <nav aria-label="Primary" class="hidden lg:block sticky top-0 z-40">
    <div class="nav3d">
      <div class="max-w-7xl mx-auto px-[15px] flex items-center gap-4 min-h-[56px]">
        <a href="<%= root_path %>" data-header-target="compact" class="hidden shrink-0 py-2">
          <%= image_tag "logo-transparent.png", alt: "Zoomora Toys", class: "h-8 w-auto" %>
        </a>

        <ul class="flex flex-1 flex-wrap items-center justify-center gap-x-1.5 gap-y-1.5 py-2.5">
          <% nav_items.each do |item| %>
            <li>
              <%= link_to item[:label], item[:url],
                    "aria-current": (helpers.current_page?(item[:url]) ? "page" : nil),
                    class: "nav3d-link px-3.5 py-[7px] text-[12.5px] font-semibold uppercase tracking-[0.045em] whitespace-nowrap focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-400 #{'is-active' if helpers.current_page?(item[:url])}" %>
            </li>
          <% end %>
        </ul>

        <div data-header-target="compact" class="hidden shrink-0 items-center gap-2 text-grey-100">
          <a href="#" aria-label="Search" class="flex items-center justify-center w-9 h-9 rounded-[3px] hover:bg-white/10 hover:text-white transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-400">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          </a>
          <a href="#" aria-label="Cart" class="relative flex items-center justify-center w-9 h-9 rounded-[3px] hover:bg-white/10 hover:text-white transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-400">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><path d="M4 5h2l2 12h9l2-8H7"/><circle cx="9" cy="20" r="1"/><circle cx="17" cy="20" r="1"/></svg>
            <span class="absolute top-0 right-0 min-w-[15px] h-[15px] px-1 flex items-center justify-center bg-red-600 text-white text-[9px] font-bold rounded-full">0</span>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <%= render Layout::MobileNavComponent.new(items: nav_items) %>
</div>
