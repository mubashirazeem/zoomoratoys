<div
  data-nav-drawer-target="panel"
  class="hidden fixed inset-0 z-50 lg:hidden"
  tabindex="-1"
  role="dialog"
  aria-modal="true"
  aria-label="Menu"
>
  <div class="absolute inset-0 bg-ink-950/50" data-action="click->nav-drawer#close"></div>

  <div class="absolute inset-y-0 right-0 w-full max-w-xs bg-white shadow-elevated flex flex-col">
    <div class="flex items-center justify-between h-16 px-4 border-b border-grey-200">
      <p class="font-display font-semibold text-h3 text-ink-950">Menu</p>
      <button
        type="button"
        data-action="nav-drawer#close"
        aria-label="Close menu"
        class="flex items-center justify-center w-10 h-10 rounded-md text-ink-950 hover:bg-grey-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-600"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" class="w-6 h-6" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>

    <nav aria-label="Primary" class="flex flex-col p-4 gap-1">
      <% items.each do |item| %>
        <%= link_to item[:label], item[:url], class: "px-3 py-3 rounded-md text-body font-display font-semibold text-ink-950 hover:bg-grey-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-600" %>
      <% end %>
    </nav>
  </div>
</div>
