<div class="group flex flex-col items-center text-center gap-3 rounded-[14px] border border-grey-200 bg-white p-6 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-transparent hover:shadow-[0_18px_36px_-20px_rgba(10,10,11,0.3)]">
  <span class="flex items-center justify-center w-12 h-12 rounded-full bg-red-600/10 text-red-600 transition-colors duration-300 group-hover:bg-red-600 group-hover:text-white">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6" aria-hidden="true">
      <% case icon %>
      <% when "shipping" %>
        <path d="M3 7h11v9H3z" />
        <path d="M14 10h4l3 3v3h-7z" />
        <circle cx="7" cy="18" r="1.6" />
        <circle cx="17.5" cy="18" r="1.6" />
      <% when "support" %>
        <path d="M4 13v-1a8 8 0 0 1 16 0v1" />
        <path d="M4 13a2 2 0 0 1 2-2 2 2 0 0 1 2 2v2a2 2 0 0 1-2 2 2 2 0 0 1-2-2Z" />
        <path d="M20 13a2 2 0 0 0-2-2 2 2 0 0 0-2 2v2a2 2 0 0 0 2 2 2 2 0 0 0 2-2Z" />
        <path d="M18 17v1a2 2 0 0 1-2 2h-2" />
      <% when "quality" %>
        <path d="M12 3.5 14.6 8.7 20.4 9.5 16.2 13.6 17.2 19.4 12 16.6 6.8 19.4 7.8 13.6 3.6 9.5 9.4 8.7Z" />
      <% when "warranty" %>
        <path d="M12 3.5 19 6.5v5c0 4.4-3 7.7-7 8.9-4-1.2-7-4.5-7-8.9v-5Z" />
        <path d="m9.3 12 1.9 1.9 3.5-3.9" />
      <% end %>
    </svg>
  </span>
  <h3 class="text-h3 font-display text-ink-950"><%= title %></h3>
  <p class="text-body-sm text-grey-500"><%= description %></p>
</div>
