<section class="max-w-7xl mx-auto px-[15px] py-14 lg:py-20 overflow-x-hidden">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
    <div class="relative">
      <div class="absolute -bottom-2 -right-2 lg:-bottom-6 lg:-right-6 w-full h-full bg-gradient-to-br from-red-600 to-red-800 rotate-1 lg:rotate-2" aria-hidden="true"></div>

      <div class="relative overflow-hidden">
        <%= image_tag "category-atv.jpg", alt: "", class: "w-full h-[300px] lg:h-[420px] object-cover" %>
      </div>

      <div class="brand-badge absolute -top-3 -left-3 lg:-top-8 lg:-left-8 flex flex-col items-center justify-center w-[104px] h-[104px] lg:w-[124px] lg:h-[124px] text-center px-2">
        <p class="text-[34px] lg:text-[40px] font-display font-bold text-ink-950 leading-none"><%= category_count %></p>
        <p class="mt-1.5 text-[10px] font-semibold uppercase tracking-[0.06em] text-grey-600 leading-tight">Adventure<br>Categories</p>
      </div>
    </div>

    <div>
      <p class="text-[12px] uppercase font-semibold tracking-[0.08em] text-red-600">Who We Are</p>
      <h2 class="mt-3 text-[28px] lg:text-h1 font-display font-bold text-ink-950 leading-tight">Built By Parents Who Wanted Better</h2>

      <div class="mt-6 flex flex-col gap-4 text-body-lg text-grey-600 leading-relaxed max-w-xl">
        <p>Zoomora started with a simple frustration: e-bikes and scooters that looked exciting online and fell apart in the driveway. So a small team of parents in Dubai set out to build something families could actually trust.</p>
        <p>Every product in our catalog — from a commuter e-bike to a full-size adventure ATV — is chosen for one reason first: it has to survive the way families really use it, weekend after weekend, in real UAE heat.</p>
      </div>

      <div class="mt-7 flex flex-wrap gap-3">
        <span class="brand-chip px-4 py-2 text-[12px] font-semibold text-ink-950">Dubai-Based Team</span>
        <span class="brand-chip px-4 py-2 text-[12px] font-semibold text-ink-950">Manufacturer Warranty</span>
        <span class="brand-chip px-4 py-2 text-[12px] font-semibold text-ink-950">UAE-Wide Delivery</span>
      </div>

      <div class="mt-8">
        <%= link_to about_path, class: "inline-flex items-center gap-2 font-display font-semibold text-[14px] uppercase tracking-[0.04em] text-red-600 hover:text-red-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600" do %>
          Our Full Story
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        <% end %>
      </div>
    </div>
  </div>
</section>
