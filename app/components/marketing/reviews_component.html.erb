<section class="max-w-7xl mx-auto px-[15px] py-14 lg:py-16">
  <div class="text-center mb-10">
    <h2 class="text-h2 font-display text-ink-950">Let Customers Speak For Us</h2>
    <div class="mt-3 flex items-center justify-center gap-2">
      <span class="flex items-center gap-0.5" aria-hidden="true">
        <% 5.times do %>
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-red-600"><path d="m12 3.5 2.6 5.2 5.8.8-4.2 4.1 1 5.8-5.2-2.8-5.2 2.8 1-5.8-4.2-4.1 5.8-.8Z"/></svg>
        <% end %>
      </span>
      <span class="text-body-sm text-grey-600"><span class="font-semibold text-ink-950"><%= average_rating %></span> · from <%= formatted_review_count %> reviews</span>
    </div>
  </div>

  <ul class="grid grid-cols-1 md:grid-cols-3 gap-[30px]">
    <% reviews.each do |review| %>
      <li class="flex flex-col items-center text-center gap-4 rounded-[14px] border border-grey-200 bg-white p-8 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-transparent hover:shadow-[0_4px_14px_-6px_rgba(192,24,39,0.1),0_26px_48px_-24px_rgba(10,10,11,0.22)]">
        <span class="flex items-center gap-0.5" aria-label="<%= review.stars %> out of 5 stars">
          <% review.stars.times do %>
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-red-600" aria-hidden="true"><path d="m12 3.5 2.6 5.2 5.8.8-4.2 4.1 1 5.8-5.2-2.8-5.2 2.8 1-5.8-4.2-4.1 5.8-.8Z"/></svg>
          <% end %>
        </span>
        <p class="text-body text-grey-600 leading-relaxed">&ldquo;<%= review.quote %>&rdquo;</p>
        <div class="mt-2 flex flex-col items-center gap-3">
          <%= image_tag review.image, alt: "", loading: "lazy", class: "w-14 h-14 object-cover rounded-full" %>
          <span class="text-body-sm font-semibold text-ink-950"><%= review.author %></span>
        </div>
      </li>
    <% end %>
  </ul>
</section>
