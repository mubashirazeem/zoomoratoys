<section
  data-controller="slideshow"
  aria-label="Featured promotions"
  aria-roledescription="carousel"
  class="relative w-full overflow-hidden h-[440px] md:h-[500px] lg:h-[560px] bg-ink-950"
>
  <% slides.each_with_index do |slide, index| %>
    <div
      data-slideshow-target="slide"
      role="group"
      aria-roledescription="slide"
      aria-label="<%= index + 1 %> of <%= slides.size %>"
      class="absolute inset-0 transition-opacity duration-700 ease-out <%= index.zero? ? 'opacity-100' : 'opacity-0 pointer-events-none' %>"
    >
      <%= image_tag slide[:image], alt: "", class: "absolute inset-0 w-full h-full object-cover object-center" %>
      <div class="absolute inset-0 bg-gradient-to-r from-ink-950/85 via-ink-950/45 to-transparent" aria-hidden="true"></div>

      <div class="relative h-full max-w-7xl mx-auto px-[15px] flex items-center">
        <div class="max-w-lg">
          <p class="text-[13px] font-semibold uppercase tracking-[0.18em] text-red-500 mb-3"><%= slide[:eyebrow] %></p>
          <h2 class="font-display font-bold uppercase text-white leading-[1.05] text-[36px] md:text-[46px] lg:text-[56px] text-balance"><%= slide[:headline] %></h2>
          <div class="mt-8">
            <%= link_to slide[:cta_url], class: "inline-flex items-center gap-3 bg-red-600 text-white font-display font-bold uppercase tracking-[0.04em] text-[15px] px-8 py-4 hover:bg-red-700 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white" do %>
              <%= slide[:cta_label] %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <button type="button" data-action="slideshow#prev" aria-label="Previous slide"
    class="absolute left-3 lg:left-5 top-1/2 -translate-y-1/2 z-10 w-10 h-10 lg:w-12 lg:h-12 flex items-center justify-center rounded-full bg-white/85 text-ink-950 hover:bg-white transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-white">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
  </button>
  <button type="button" data-action="slideshow#next" aria-label="Next slide"
    class="absolute right-3 lg:right-5 top-1/2 -translate-y-1/2 z-10 w-10 h-10 lg:w-12 lg:h-12 flex items-center justify-center rounded-full bg-white/85 text-ink-950 hover:bg-white transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-white">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
  </button>

  <div class="absolute bottom-5 left-1/2 -translate-x-1/2 z-10 flex items-center gap-2.5">
    <% slides.each_with_index do |_slide, index| %>
      <button type="button" data-action="slideshow#goto" data-index="<%= index %>" data-slideshow-target="dot"
        aria-label="Go to slide <%= index + 1 %>"
        class="w-2.5 h-2.5 rounded-full transition-colors <%= index.zero? ? 'bg-white' : 'bg-white/40' %> hover:bg-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-white"></button>
    <% end %>
  </div>
</section>
