<section class="max-w-7xl mx-auto px-[15px] py-14 lg:py-16">
  <%= render Marketing::CenteredHeadingComponent.new(title: "Official Brand Partners") %>
  <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 lg:gap-5">
    <% partners.each do |partner| %>
      <li class="group flex flex-col items-center gap-4 rounded-[14px] border border-grey-200 bg-white px-4 py-6 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-transparent hover:shadow-[0_18px_36px_-20px_rgba(10,10,11,0.35)]">
        <span class="flex items-center justify-center w-16 h-16 rounded-full bg-grey-50 text-ink-950 font-display font-bold text-[30px] transition-colors duration-300 group-hover:bg-red-600 group-hover:text-white" aria-hidden="true"><%= partner.monogram %></span>
        <span class="text-[12px] font-semibold uppercase tracking-[0.12em] text-grey-500 transition-colors duration-300 group-hover:text-ink-950"><%= partner.name %></span>
      </li>
    <% end %>
  </ul>
</section>
