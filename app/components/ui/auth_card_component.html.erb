<div class="max-w-7xl mx-auto my-8 lg:my-12 px-[15px]">
  <div class="grid lg:grid-cols-2 rounded-[20px] overflow-hidden border border-grey-200 shadow-[0_20px_60px_-30px_rgba(10,10,11,0.25)] lg:min-h-[620px]">
    <%# ---- Photo panel: real brand photography, hidden below lg: so the ---- %>
    <%# form always loads first on mobile. The site's own header already   %>
    <%# carries the logo, so this panel doesn't repeat it.                 %>
    <div class="hidden lg:block relative bg-ink-950">
      <%= image_tag "hero-bicycle.jpg", alt: "", class: "absolute inset-0 w-full h-full object-cover" %>
      <div class="absolute inset-0 bg-gradient-to-t from-ink-950/90 via-ink-950/20 to-ink-950/50" aria-hidden="true"></div>

      <div class="relative h-full flex flex-col justify-end p-12">
        <p class="text-[13px] uppercase font-semibold tracking-[0.2em] text-red-400 mb-3">Family Adventure Store</p>
        <h2 class="text-[36px] font-display font-bold text-white leading-tight max-w-sm">Adventure Starts Here.</h2>
        <p class="mt-4 text-body-lg text-grey-300 max-w-sm">Electric bikes, scooters, ATVs, and more — built for real family use, backed by real support.</p>
      </div>
    </div>

    <%# ---- Form panel ---- %>
    <div class="flex items-center justify-center px-[15px] py-14 bg-white">
      <div class="w-full max-w-md">
        <p class="text-[12px] uppercase font-semibold tracking-[0.16em] text-red-600 text-center lg:text-left"><%= eyebrow %></p>
        <h1 class="mt-2 text-[30px] lg:text-[34px] font-display font-bold text-ink-950 text-center lg:text-left"><%= title %></h1>

        <div class="mt-8">
          <%= body %>
        </div>
      </div>
    </div>
  </div>
</div>
