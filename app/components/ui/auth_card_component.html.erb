<div class="max-w-7xl mx-auto px-[15px] py-8 lg:py-14">
  <%= render Ui::BreadcrumbComponent.new(items: [
    { label: "Home", url: root_path },
    { label: breadcrumb_label }
  ]) %>

  <div class="mt-8 max-w-md mx-auto">
    <div class="text-center">
      <p class="text-[12px] uppercase font-semibold tracking-[0.08em] text-red-600"><%= eyebrow %></p>
      <h1 class="mt-2 text-[28px] lg:text-[32px] font-display font-bold text-ink-950"><%= title %></h1>
    </div>

    <div class="mt-8 rounded-[18px] border border-grey-200 bg-white p-6 lg:p-8 shadow-[0_10px_30px_-24px_rgba(10,10,11,0.4)]">
      <%= body %>
    </div>
  </div>
</div>
