<nav aria-label="Pagination" class="mt-10 flex items-center justify-center gap-2">
  <% if current_page > 1 %>
    <%= link_to url_for_page(current_page - 1), "aria-label": "Previous page",
          class: "flex items-center justify-center w-10 h-10 rounded-full border border-grey-300 text-ink-950 hover:border-red-600 hover:text-red-600 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-600" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
    <% end %>
  <% end %>

  <% page_items.each do |page| %>
    <% if page.nil? %>
      <span class="w-10 h-10 flex items-center justify-center text-grey-400" aria-hidden="true">&hellip;</span>
    <% elsif page == current_page %>
      <span aria-current="page" class="flex items-center justify-center w-10 h-10 rounded-full bg-red-600 text-white text-body-sm font-semibold"><%= page %></span>
    <% else %>
      <%= link_to page, url_for_page(page),
            class: "flex items-center justify-center w-10 h-10 rounded-full text-body-sm font-medium text-ink-950 hover:bg-grey-50 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-600" %>
    <% end %>
  <% end %>

  <% if current_page < total_pages %>
    <%= link_to url_for_page(current_page + 1), "aria-label": "Next page",
          class: "flex items-center justify-center w-10 h-10 rounded-full border border-grey-300 text-ink-950 hover:border-red-600 hover:text-red-600 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-600" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
    <% end %>
  <% end %>
</nav>
