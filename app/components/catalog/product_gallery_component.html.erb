<div data-controller="gallery" class="flex flex-col gap-4">
  <div class="relative bg-grey-50 border border-grey-200">
    <% if badge %>
      <div class="absolute top-4 left-4 z-10">
        <%= render Ui::BadgeComponent.new(variant: badge) %>
      </div>
    <% end %>
    <%= image_tag image, alt: product.name, data: { "gallery-target": "main" }, class: "aspect-square w-full object-cover" %>
  </div>

  <div class="grid grid-cols-4 gap-3">
    <% thumbnails.each_with_index do |thumb, index| %>
      <button type="button"
        data-action="gallery#select"
        data-gallery-target="thumb"
        aria-label="View image <%= index + 1 %>"
        class="bg-grey-50 border-2 <%= index.zero? ? 'border-red-600' : 'border-grey-200' %> hover:border-red-600 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-600">
        <%= image_tag thumb, alt: "", loading: "lazy", class: "aspect-square w-full object-cover" %>
      </button>
    <% end %>
  </div>
</div>
