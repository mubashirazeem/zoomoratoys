<%= link_to url, class: "group relative block overflow-hidden focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600" do %>
  <%= image_tag "category-#{category.placeholder_key}.jpg", alt: "", loading: "lazy", class: "aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-105" %>
  <div class="absolute inset-x-0 bottom-0 bg-red-600 group-hover:bg-red-700 transition-colors py-4 px-5">
    <h3 class="text-white font-display font-bold uppercase text-center text-[22px] lg:text-[26px] leading-none tracking-[0.02em]"><%= label %></h3>
  </div>
<% end %>
