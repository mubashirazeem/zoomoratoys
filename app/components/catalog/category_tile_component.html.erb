<%= link_to url, class: "group relative block overflow-hidden rounded-[14px] bg-white transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-[0_4px_14px_-6px_rgba(192,24,39,0.14),0_26px_48px_-22px_rgba(10,10,11,0.35)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600" do %>
  <%= image_tag "category-#{category.placeholder_key}.jpg", alt: "", loading: "lazy", class: "aspect-[16/10] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-110" %>
  <div class="absolute inset-x-0 bottom-0 flex items-center justify-center gap-2.5 bg-red-600 group-hover:bg-red-700 transition-colors py-4 px-5">
    <h3 class="text-white font-display font-bold uppercase text-center text-[22px] lg:text-[26px] leading-none tracking-[0.02em]"><%= label %></h3>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-white shrink-0 -translate-x-2 opacity-0 transition-all duration-200 group-hover:translate-x-0 group-hover:opacity-100" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
  </div>
<% end %>
