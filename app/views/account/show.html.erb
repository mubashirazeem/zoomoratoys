<% content_for :title, "My Account | Zoomora" %>

<div class="max-w-7xl mx-auto px-[15px] py-8 lg:py-10">
  <%= render Ui::BreadcrumbComponent.new(items: [
    { label: "Home", url: root_path },
    { label: "My Account" }
  ]) %>

  <h1 class="mt-4 text-[32px] lg:text-[40px] font-display font-bold text-ink-950 leading-tight">
    Hi, <%= current_user.first_name %>
  </h1>
  <p class="mt-2 text-body text-grey-600"><%= current_user.email %></p>

  <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <%= link_to account_orders_path, class: "group rounded-[18px] border border-grey-200 bg-white p-6 hover:border-red-600 transition-colors" do %>
      <span class="flex items-center justify-center w-12 h-12 rounded-full bg-red-600/10 text-red-600">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6" aria-hidden="true"><path d="M20 7 12 3 4 7v10l8 4 8-4V7Z"/><path d="M4 7l8 4 8-4M12 11v10"/></svg>
      </span>
      <h2 class="mt-4 font-display font-bold text-ink-950 group-hover:text-red-600 transition-colors">Order History</h2>
      <p class="mt-1 text-body-sm text-grey-500"><%= @order_count %> <%= "order".pluralize(@order_count) %></p>
    <% end %>

    <%= link_to wishlist_path, class: "group rounded-[18px] border border-grey-200 bg-white p-6 hover:border-red-600 transition-colors" do %>
      <span class="flex items-center justify-center w-12 h-12 rounded-full bg-red-600/10 text-red-600">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6" aria-hidden="true"><path d="M12 20s-7-4.3-7-9a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 4.7-7 9-7 9Z"/></svg>
      </span>
      <h2 class="mt-4 font-display font-bold text-ink-950 group-hover:text-red-600 transition-colors">Wishlist</h2>
      <p class="mt-1 text-body-sm text-grey-500"><%= @wishlist_item_count %> <%= "item".pluralize(@wishlist_item_count) %></p>
    <% end %>

    <%= link_to edit_user_registration_path, class: "group rounded-[18px] border border-grey-200 bg-white p-6 hover:border-red-600 transition-colors" do %>
      <span class="flex items-center justify-center w-12 h-12 rounded-full bg-red-600/10 text-red-600">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-3.3 3.6-6 8-6s8 2.7 8 6"/></svg>
      </span>
      <h2 class="mt-4 font-display font-bold text-ink-950 group-hover:text-red-600 transition-colors">Account Settings</h2>
      <p class="mt-1 text-body-sm text-grey-500">Name, email, password</p>
    <% end %>
  </div>

  <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "mt-8 inline-block text-body-sm font-semibold text-grey-500 hover:text-red-600 transition-colors" %>
</div>
