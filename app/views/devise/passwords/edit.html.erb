<% content_for :title, "Change Password | Zoomora" %>

<% field_classes = "w-full rounded-[12px] border border-grey-300 bg-grey-50 px-4 py-3 text-body text-ink-950 placeholder:text-grey-400 transition focus:bg-white focus:border-red-600 focus:ring-4 focus:ring-red-600/10 focus:outline-none" %>

<%= render Ui::AuthCardComponent.new(eyebrow: "Account Recovery", title: "Change Your Password", breadcrumb_label: "Change Password") do |card| %>
  <% card.with_body do %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "flex flex-col gap-5" }) do |f| %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <%= f.label :password, "New Password", class: "block text-body-sm font-medium text-ink-950 mb-1.5" %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: field_classes %>
        <% if @minimum_password_length %>
          <p class="mt-1.5 text-body-sm text-grey-500"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm New Password", class: "block text-body-sm font-medium text-ink-950 mb-1.5" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: field_classes %>
      </div>

      <%= render(Ui::ButtonComponent.new(variant: :primary, size: :lg, full_width: true, type: "submit")) { "Change My Password" } %>
    <% end %>
  <% end %>
<% end %>
