<%# locals: f:, field_classes:, field: (optional, default :password), label_text: (optional), hint: (optional), autofocus: (optional), minimum_length: (optional) %>
<% field = local_assigns[:field] || :password %>
<% label_text = local_assigns[:label_text] || "Password" %>
<% hint = local_assigns[:hint] %>
<% autofocus = local_assigns[:autofocus] %>
<% minimum_length = local_assigns[:minimum_length] %>

<div data-controller="password-strength">
  <%= f.label field, label_text, class: "block text-body-sm font-medium text-ink-950 mb-1.5" %>
  <% if hint %>
    <p class="text-body-sm text-grey-500 mb-1.5"><%= hint %></p>
  <% end %>
  <%= f.password_field field, autofocus: autofocus, autocomplete: "new-password", class: field_classes,
        data: { "password-strength-target": "input", action: "input->password-strength#check" } %>
  <% if minimum_length %>
    <p class="mt-1.5 text-body-sm text-grey-500"><%= minimum_length %> characters minimum</p>
  <% end %>

  <div class="mt-2.5 flex items-center gap-3">
    <svg viewBox="0 0 36 36" class="w-8 h-8 -rotate-90 shrink-0" aria-hidden="true">
      <circle cx="18" cy="18" r="15" fill="none" stroke="rgba(10,10,11,0.1)" stroke-width="3"></circle>
      <circle data-password-strength-target="ring" cx="18" cy="18" r="15" fill="none" stroke="#C01827" stroke-width="3"
        stroke-dasharray="94.2" stroke-dashoffset="94.2" stroke-linecap="round" class="transition-[stroke-dashoffset] duration-300"></circle>
    </svg>
    <p data-password-strength-target="label" class="text-body-sm text-grey-500">Enter a password</p>
  </div>
</div>
