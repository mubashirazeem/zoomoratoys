<div class="flex flex-col items-center gap-2 text-body-sm text-grey-600">
  <%- if controller_name != "sessions" %>
    <p><%= link_to "Already have an account? Sign in", new_session_path(resource_name), class: "text-red-600 font-medium hover:text-red-700" %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != "registrations" %>
    <p><%= link_to "New here? Create an account", new_registration_path(resource_name), class: "text-red-600 font-medium hover:text-red-700" %></p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <p><%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-red-600 font-medium hover:text-red-700" %></p>
  <% end %>
</div>
