<% content_for :title, "Sign In | Zoomora" %>

<% field_classes = "w-full rounded-[12px] border border-grey-300 bg-grey-50 px-4 py-3 text-body text-ink-950 placeholder:text-grey-400 transition focus:bg-white focus:border-red-600 focus:ring-4 focus:ring-red-600/10 focus:outline-none" %>
<% label_classes = "block text-body-sm font-medium text-ink-950 mb-1.5" %>

<%= render Ui::AuthCardComponent.new(eyebrow: "Welcome Back", title: "Sign In") do |card| %>
  <% card.with_body do %>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "flex flex-col gap-5" }) do |f| %>
      <div>
        <%= f.label :email, class: label_classes %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: field_classes %>
      </div>

      <div>
        <%= f.label :password, class: label_classes %>
        <%= f.password_field :password, autocomplete: "current-password", class: field_classes %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-2.5 text-body-sm text-ink-950 cursor-pointer">
          <%= f.check_box :remember_me, class: "w-4 h-4 accent-red-600" %>
          <%= f.label :remember_me, "Remember me", class: "cursor-pointer" %>
        </label>
      <% end %>

      <%= render(Ui::ButtonComponent.new(variant: :primary, size: :lg, full_width: true, type: "submit")) { "Log In" } %>
    <% end %>

    <div class="mt-6 pt-6 border-t border-grey-200">
      <%= render "devise/shared/links" %>
    </div>
  <% end %>
<% end %>
