<% content_for :title, "Account Settings | Zoomora" %>

<% field_classes = "w-full rounded-[12px] border border-grey-300 bg-grey-50 px-4 py-3 text-body text-ink-950 placeholder:text-grey-400 transition focus:bg-white focus:border-red-600 focus:ring-4 focus:ring-red-600/10 focus:outline-none" %>
<% label_classes = "block text-body-sm font-medium text-ink-950 mb-1.5" %>

<%= render Ui::AuthCardComponent.new(eyebrow: "My Account", title: "Account Settings") do |card| %>
  <% card.with_body do %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "flex flex-col gap-5" }) do |f| %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <%= f.label :first_name, class: label_classes %>
          <%= f.text_field :first_name, class: field_classes %>
        </div>
        <div>
          <%= f.label :last_name, class: label_classes %>
          <%= f.text_field :last_name, class: field_classes %>
        </div>
      </div>

      <div>
        <%= f.label :email, class: label_classes %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: field_classes %>
      </div>

      <div class="pt-2 border-t border-grey-200">
        <%= render "devise/shared/password_field_with_strength", f: f, field_classes: field_classes,
              hint: "Leave blank if you don't want to change it", minimum_length: @minimum_password_length %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm New Password", class: label_classes %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: field_classes %>
      </div>

      <div>
        <%= f.label :current_password, class: label_classes %>
        <p class="text-body-sm text-grey-500 mb-1.5">We need your current password to confirm these changes</p>
        <%= f.password_field :current_password, autocomplete: "current-password", class: field_classes %>
      </div>

      <%= render(Ui::ButtonComponent.new(variant: :primary, size: :lg, full_width: true, type: "submit")) { "Update Account" } %>
    <% end %>

    <div class="mt-6 pt-6 border-t border-grey-200 flex items-center justify-between gap-4">
      <p class="text-body-sm text-grey-500">Unhappy with Zoomora?</p>
      <%= button_to "Cancel My Account", registration_path(resource_name),
            data: { turbo_confirm: "Are you sure? This can't be undone." },
            method: :delete,
            class: "text-body-sm font-medium text-red-600 hover:text-red-700" %>
    </div>
  <% end %>
<% end %>
