<% content_for :title, "About Us | Zoomora" %>
<% content_for :meta_description, "Zoomora is a family adventure store built around one idea: the best childhoods happen outside." %>

<div class="max-w-7xl mx-auto px-[15px] py-8">
  <%= render Ui::BreadcrumbComponent.new(items: [
    { label: "Home", url: root_path },
    { label: "About Us" }
  ]) %>
</div>

<%# ---- Hero banner ---- %>
<section class="max-w-7xl mx-auto px-[15px]">
  <div class="relative overflow-hidden rounded-[24px] bg-ink-950">
    <%= image_tag "hero-bicycle.jpg", alt: "", class: "w-full h-[300px] lg:h-[420px] object-cover" %>
    <div class="absolute inset-0 bg-gradient-to-r from-ink-950/90 via-ink-950/55 to-ink-950/10" aria-hidden="true"></div>
    <div class="absolute inset-0 flex flex-col justify-center p-8 lg:p-16 max-w-2xl">
      <p class="text-[12px] uppercase font-semibold tracking-[0.12em] text-red-400 mb-3">About Zoomora</p>
      <h1 class="text-[34px] lg:text-[52px] font-display font-bold text-white leading-[1.05]">Adventure Starts Here.</h1>
      <p class="mt-4 text-body-lg text-grey-200 max-w-lg">A family adventure store built around one idea — the best childhoods happen outside, moving, on something with a motor or pedals of its own.</p>
    </div>
  </div>
</section>

<%# ---- Story ---- %>
<section class="max-w-7xl mx-auto px-[15px] py-14 lg:py-20 overflow-hidden">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-24 items-center">
    <div>
      <p class="text-[12px] uppercase font-semibold tracking-[0.08em] text-red-600">Our Story</p>
      <h2 class="mt-3 text-[28px] lg:text-h1 font-display font-bold text-ink-950 leading-tight">Built By Parents Who Wanted Better</h2>
      <div class="mt-6 flex flex-col gap-4 text-body-lg text-grey-600 leading-relaxed max-w-xl">
        <p>Zoomora exists around one simple idea: the best childhoods happen outside. Not in front of a screen, not stuck indoors waiting out the heat — outside, moving, steering something with a motor or pedals of its own.</p>
        <p>We started as a small team of parents tired of choosing between products that looked exciting online and arrived feeling flimsy in the driveway. So we built a store around a narrower promise: every e-bike, scooter, dirt bike, and ATV we carry has to hold up to the way families actually use it — every weekend, in real heat, for years.</p>
      </div>
    </div>

    <div class="relative">
      <div class="absolute -bottom-4 -right-4 lg:-bottom-6 lg:-right-6 w-full h-full rounded-[20px] bg-gradient-to-br from-red-600 to-red-800 rotate-2" aria-hidden="true"></div>
      <div class="relative overflow-hidden rounded-[20px]">
        <%= image_tag "category-dirtbike.jpg", alt: "", class: "w-full h-[320px] lg:h-[440px] object-cover" %>
      </div>
    </div>
  </div>
</section>

<%# ---- Stats strip ---- %>
<section class="max-w-7xl mx-auto px-[15px] pb-14 lg:pb-20">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
    <% [
      [Category::PLACEHOLDER_KEYS.size.to_s, "Adventure Categories"],
      ["100%", "Checked Before Shipping"],
      ["12-Mo", "Manufacturer Warranty"],
      ["Free", "UAE-Wide Delivery"]
    ].each do |value, label| %>
      <div class="rounded-[16px] border border-grey-200 bg-white p-6 text-center transition-all duration-300 ease-out hover:-translate-y-1 hover:border-transparent hover:shadow-[0_18px_36px_-20px_rgba(10,10,11,0.3)]">
        <p class="text-[34px] lg:text-[42px] font-display font-bold text-red-600 leading-none"><%= value %></p>
        <p class="mt-2 text-body-sm font-medium text-grey-600"><%= label %></p>
      </div>
    <% end %>
  </div>
</section>

<%# ---- Promise band ---- %>
<section class="bg-grey-50">
  <div class="max-w-3xl mx-auto px-[15px] py-14 lg:py-20 text-center flex flex-col gap-4">
    <p class="text-[12px] uppercase font-semibold tracking-[0.08em] text-red-600">Our Promise</p>
    <h2 class="text-h2 font-display text-ink-950">Built On A Promise</h2>
    <p class="text-body-lg text-grey-600 leading-relaxed">That promise shapes everything else. We keep the catalog broad — from a first commuter e-bike to a full-size adventure ATV for the whole family — because adventure doesn't stop at one age group.</p>
    <p class="text-body-lg text-grey-600 leading-relaxed">And we keep the buying experience simple: clear pricing, honest descriptions, and a team that answers when you have a real question about a real product, not a script. We're based in Dubai and shipping across the UAE, with a catalog that keeps growing as we find products worth standing behind.</p>
  </div>
</section>

<%# ---- What we care about ---- %>
<section class="max-w-7xl mx-auto px-[15px] py-14 lg:py-20">
  <%= render Marketing::CenteredHeadingComponent.new(title: "What We Care About") %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
    <%= render Marketing::TrustBadgeComponent.new(icon: "quality", title: "Built to Last", description: "We choose products for durability first, features second.") %>
    <%= render Marketing::TrustBadgeComponent.new(icon: "support", title: "Real Support", description: "Questions get answered by people who know the products.") %>
    <%= render Marketing::TrustBadgeComponent.new(icon: "warranty", title: "Stand Behind It", description: "Every vehicle we sell is backed by a manufacturer warranty.") %>
  </div>
</section>

<div class="max-w-7xl mx-auto px-[15px] pb-14 lg:pb-16">
  <%= render Marketing::CtaBannerComponent.new(
    title: "See What's New At Zoomora",
    description: "Browse the full catalog and find the perfect ride for your family.",
    cta_label: "Shop All Products",
    cta_url: products_path,
    tone: :dark
  ) %>
</div>
