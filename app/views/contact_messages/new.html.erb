<% content_for :title, "Contact Us | Zoomora" %>
<% content_for :meta_description, "Get in touch with the Zoomora team — questions, orders, and support." %>

<% field_classes = "w-full rounded-[12px] border border-grey-300 bg-grey-50 px-4 py-3 text-body text-ink-950 placeholder:text-grey-400 transition focus:bg-white focus:border-red-600 focus:ring-4 focus:ring-red-600/10 focus:outline-none" %>

<div class="max-w-7xl mx-auto px-[15px] py-8">
  <%= render Ui::BreadcrumbComponent.new(items: [
    { label: "Home", url: root_path },
    { label: "Contact Us" }
  ]) %>

  <div class="mt-4">
    <p class="text-[12px] uppercase font-semibold tracking-[0.08em] text-red-600">Get In Touch</p>
    <h1 class="mt-2 text-[32px] lg:text-[40px] font-display font-bold text-ink-950 leading-tight">Contact Us</h1>
    <p class="mt-3 text-body text-grey-500 max-w-2xl">Questions about a product, an order, or just want to talk adventure gear? We'd love to hear from you.</p>
  </div>

  <div class="mt-10 grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10">
    <div class="lg:col-span-2 rounded-[18px] border border-grey-200 bg-white p-6 lg:p-8 shadow-[0_14px_36px_-24px_rgba(10,10,11,0.4)]">
      <%= form_with model: @contact_message, url: contact_path, class: "flex flex-col gap-5" do |form| %>
        <% if @contact_message.errors.any? %>
          <div role="alert" class="rounded-[12px] bg-red-50 border border-red-200 px-4 py-3 text-body-sm text-red-700">
            <p class="font-semibold">Please fix the following before submitting:</p>
            <ul class="mt-1 list-disc list-inside">
              <% @contact_message.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <%= form.label :name, class: "block text-body-sm font-medium text-ink-950 mb-1.5" %>
            <%= form.text_field :name, required: true,
                  "aria-invalid": @contact_message.errors[:name].any?,
                  "aria-describedby": ("name-error" if @contact_message.errors[:name].any?),
                  class: "#{field_classes} #{'border-red-600' if @contact_message.errors[:name].any?}" %>
            <% if @contact_message.errors[:name].any? %>
              <p id="name-error" class="mt-1 text-body-sm text-red-700"><%= @contact_message.errors[:name].to_sentence.capitalize %></p>
            <% end %>
          </div>

          <div>
            <%= form.label :email, class: "block text-body-sm font-medium text-ink-950 mb-1.5" %>
            <%= form.email_field :email, required: true,
                  "aria-invalid": @contact_message.errors[:email].any?,
                  "aria-describedby": ("email-error" if @contact_message.errors[:email].any?),
                  class: "#{field_classes} #{'border-red-600' if @contact_message.errors[:email].any?}" %>
            <% if @contact_message.errors[:email].any? %>
              <p id="email-error" class="mt-1 text-body-sm text-red-700"><%= @contact_message.errors[:email].to_sentence.capitalize %></p>
            <% end %>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <%= form.label :phone, "Phone (optional)", class: "block text-body-sm font-medium text-ink-950 mb-1.5" %>
            <%= form.telephone_field :phone, class: field_classes %>
          </div>

          <div>
            <%= form.label :subject, class: "block text-body-sm font-medium text-ink-950 mb-1.5" %>
            <%= form.text_field :subject, required: true,
                  "aria-invalid": @contact_message.errors[:subject].any?,
                  "aria-describedby": ("subject-error" if @contact_message.errors[:subject].any?),
                  class: "#{field_classes} #{'border-red-600' if @contact_message.errors[:subject].any?}" %>
            <% if @contact_message.errors[:subject].any? %>
              <p id="subject-error" class="mt-1 text-body-sm text-red-700"><%= @contact_message.errors[:subject].to_sentence.capitalize %></p>
            <% end %>
          </div>
        </div>

        <div>
          <%= form.label :message, class: "block text-body-sm font-medium text-ink-950 mb-1.5" %>
          <%= form.text_area :message, rows: 6, required: true,
                "aria-invalid": @contact_message.errors[:message].any?,
                "aria-describedby": ("message-error" if @contact_message.errors[:message].any?),
                class: "#{field_classes} #{'border-red-600' if @contact_message.errors[:message].any?}" %>
          <% if @contact_message.errors[:message].any? %>
            <p id="message-error" class="mt-1 text-body-sm text-red-700"><%= @contact_message.errors[:message].to_sentence.capitalize %></p>
          <% end %>
        </div>

        <div>
          <%= render(Ui::ButtonComponent.new(variant: :primary, size: :lg, type: "submit")) { "Send Message" } %>
        </div>
      <% end %>
    </div>

    <div class="flex flex-col gap-4">
      <div class="group rounded-[14px] border border-grey-200 bg-white p-6 flex items-start gap-4 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-transparent hover:shadow-[0_18px_36px_-20px_rgba(10,10,11,0.28)]">
        <span class="shrink-0 flex items-center justify-center w-11 h-11 rounded-full bg-red-600/10 text-red-600 transition-colors duration-300 group-hover:bg-red-600 group-hover:text-white">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        </span>
        <div>
          <h2 class="text-h3 font-display text-ink-950">Email</h2>
          <%= link_to Layout::SiteFooterComponent::SUPPORT_EMAIL, "mailto:#{Layout::SiteFooterComponent::SUPPORT_EMAIL}", class: "text-body-sm text-grey-600 hover:text-red-600" %>
        </div>
      </div>

      <div class="group rounded-[14px] border border-grey-200 bg-white p-6 flex items-start gap-4 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-transparent hover:shadow-[0_18px_36px_-20px_rgba(10,10,11,0.28)]">
        <span class="shrink-0 flex items-center justify-center w-11 h-11 rounded-full bg-red-600/10 text-red-600 transition-colors duration-300 group-hover:bg-red-600 group-hover:text-white">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><path d="M4 5c0 8.3 6.7 15 15 15a2 2 0 0 0 2-2v-2.5a1 1 0 0 0-.8-1l-3.4-.7a1 1 0 0 0-1 .3l-1 1a12 12 0 0 1-5.2-5.2l1-1a1 1 0 0 0 .3-1L9.5 4.8A1 1 0 0 0 8.5 4H6a2 2 0 0 0-2 1Z"/></svg>
        </span>
        <div>
          <h2 class="text-h3 font-display text-ink-950">Phone</h2>
          <%= link_to Layout::SiteFooterComponent::SUPPORT_PHONE, "tel:#{Layout::SiteFooterComponent::SUPPORT_PHONE.gsub(/\s+/, '')}", class: "text-body-sm text-grey-600 hover:text-red-600" %>
        </div>
      </div>

      <div class="group rounded-[14px] border border-grey-200 bg-white p-6 flex items-start gap-4 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-transparent hover:shadow-[0_18px_36px_-20px_rgba(10,10,11,0.28)]">
        <span class="shrink-0 flex items-center justify-center w-11 h-11 rounded-full bg-red-600/10 text-red-600 transition-colors duration-300 group-hover:bg-red-600 group-hover:text-white">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
        </span>
        <div>
          <h2 class="text-h3 font-display text-ink-950">Location</h2>
          <p class="text-body-sm text-grey-600">Dubai, United Arab Emirates</p>
        </div>
      </div>

      <div class="group rounded-[14px] border border-grey-200 bg-white p-6 flex items-start gap-4 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-transparent hover:shadow-[0_18px_36px_-20px_rgba(10,10,11,0.28)]">
        <span class="shrink-0 flex items-center justify-center w-11 h-11 rounded-full bg-red-600/10 text-red-600 transition-colors duration-300 group-hover:bg-red-600 group-hover:text-white">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        </span>
        <div>
          <h2 class="text-h3 font-display text-ink-950">Hours</h2>
          <p class="text-body-sm text-grey-600">Sun–Fri, 9am–7pm (GST)</p>
        </div>
      </div>

      <div class="rounded-[14px] bg-ink-950 p-6">
        <p class="flex items-center gap-2 text-[12px] uppercase font-semibold tracking-[0.08em] text-red-400">
          <span class="relative flex w-2 h-2" aria-hidden="true">
            <span class="absolute inline-flex w-full h-full rounded-full bg-red-500 opacity-60 animate-ping"></span>
            <span class="relative inline-flex w-2 h-2 rounded-full bg-red-600"></span>
          </span>
          Fast Replies
        </p>
        <p class="mt-3 text-body-sm text-grey-300 leading-relaxed">We usually reply within <span class="font-semibold text-white">one business day</span>. For urgent help with an order, call us during store hours.</p>
      </div>
    </div>
  </div>
</div>
