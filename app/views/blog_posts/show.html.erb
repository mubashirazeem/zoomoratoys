<% content_for :title, "#{@blog_post.title} | Zoomora Blog" %>
<% content_for :meta_description, @blog_post.excerpt %>

<div class="max-w-3xl mx-auto px-[15px] py-10">
  <%= render Ui::BreadcrumbComponent.new(items: [
    { label: "Home", url: root_path },
    { label: "Blog", url: blog_posts_path },
    { label: @blog_post.title }
  ]) %>

  <p class="mt-6 text-body-sm text-grey-500"><%= @blog_post.published_at.strftime("%B %-d, %Y") %></p>
  <h1 class="mt-2 text-[28px] lg:text-h1 font-display text-ink-950 leading-tight"><%= @blog_post.title %></h1>

  <div class="mt-8 overflow-hidden rounded-[16px]">
    <%= image_tag "category-#{@blog_post.cover_image_key}.jpg", alt: "", class: "w-full h-[260px] lg:h-[380px] object-cover" %>
  </div>

  <div class="mt-8 flex flex-col gap-5 text-body-lg text-grey-600 leading-relaxed">
    <% @blog_post.body.split("\n\n").each do |paragraph| %>
      <p><%= paragraph %></p>
    <% end %>
  </div>

  <div class="mt-12 border-t border-grey-200 pt-6">
    <%= link_to blog_posts_path, class: "inline-flex items-center gap-2 font-display font-semibold text-[14px] uppercase tracking-[0.04em] text-red-600 hover:text-red-700" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
      Back to Blog
    <% end %>
  </div>
</div>
